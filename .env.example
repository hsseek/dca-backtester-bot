TELEGRAM_BOT_TOKEN="123456:ABCDEF..."
DEFAULT_FX=1450.0
DEFAULT_SELL_R=0.10
DEFAULT_INTRADAY_INTERVAL=5m
DEFAULT_DAILY_BUDGET=500
ADMIN_USER_ID=1234567890

# Monitoring Feature
# Comma-separated list of Ticker:Threshold_days (e.g., DFEN:14,QQQ:7)
# The bot will send a "Buy now!" message if the current price is the lowest in Threshold_days.
TICKERS_MONITORED=""
# Interval in seconds for checking monitored tickers. (e.g., 3600 for hourly checks)
MONITORING_INTERVAL_SECONDS=3600

# Daily Report Feature
# Set to 'true' to enable daily reports on market open.
DAILY_REPORT_ENABLED="true"